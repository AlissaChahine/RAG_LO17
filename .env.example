# =========================
# Google Gemini API
# =========================
# Required if you use Gemini embeddings or Gemini LLM.
GOOGLE_API_KEY=your_google_api_key_here

# =========================
# LLM provider
# =========================
# Choose "ollama" for local LLM or "gemini" for Gemini.
LLM_PROVIDER=ollama

# Local Ollama model.
# Make sure this model is installed locally with:
# ollama pull qwen3:8b
OLLAMA_MODEL=qwen3:8b

# Gemini LLM model, used only if LLM_PROVIDER=gemini.
GEMINI_LLM_MODEL=gemini-2.5-flash-lite

# =========================
# Embedding model
# =========================
# Must match the embedding model used when the Chroma database was created.
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# =========================
# Vector database paths
# =========================
# Default paths used by the project.
CHROMA_DIR=db/chroma_minecraft_multivec
STORE_DIR=db/local_chunks_store
CHROMA_COLLECTION=minecraft_summaries